generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppMode {
  PAPER
  LIVE
}

enum Side {
  BUY
  SELL
}

enum DecisionAction {
  EXECUTE
  SKIP
}

enum ExecutionStatus {
  SUBMITTED
  FILLED
  FAILED
  SKIPPED
}

enum PaperDecisionType {
  COPY
  SKIP
  REDUCE
  CLOSE
  BOOTSTRAP
  NOOP
}

enum PaperDecisionStatus {
  PENDING
  EXECUTED
  SKIPPED
  FAILED
}

enum PaperExecutorType {
  PAPER
  DRY_RUN
  LIVE
}

model WatchedWallet {
  id             String     @id @default(uuid())
  address        String     @unique
  label          String
  enabled        Boolean    @default(true)
  copyEnabled    Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  priorityTier   String     @default("INACTIVE")
  lastPolledAt   DateTime?
  nextPollAt     DateTime?
  syncStatus     String     @default("ACTIVE")
  lastSyncAt     DateTime?
  lastActivitySyncedAt DateTime?
  lastPositionsSyncedAt DateTime?
  lastSyncError  String?
  strategies     Strategy[]
  activityEvents WalletActivityEvent[]
  syncCursors    WalletSyncCursor[]
  reconciliationIssues WalletReconciliationIssue[]
  tradeEvents    TradeEvent[]
  analyticsSnapshots WalletAnalyticsSnapshot[]
  whaleAlerts    WhaleAlert[]
  paperSessions  PaperCopySession[]
  systemAlerts   SystemAlert[]
}

model WalletActivityEvent {
  id                String   @id @default(uuid())
  trackedWalletId   String
  walletAddress     String
  sourceName        String   @default("POLYMARKET_DATA_API")
  sourceType        String   @default("HTTP_API")
  externalEventId   String?
  sourceEventId     String?
  sourceCursor      String?
  dedupeKey         String
  eventType         String
  marketId          String
  conditionId       String?
  marketQuestion    String?
  outcome           String?
  side              Side?
  effectiveSide     Side?
  price             Decimal?
  shares            Decimal?
  notional          Decimal?
  fee               Decimal?
  blockNumber       Int?
  logIndex          Int?
  sourceTxHash      String?
  txHash            String?
  orderId           String?
  eventTimestamp    DateTime
  observedAt        DateTime?
  detectedAt        DateTime
  rawPayloadHash    String?
  rawPayloadJson    Json
  provenanceNote    String?
  createdAt         DateTime @default(now())
  trackedWallet     WatchedWallet @relation(fields: [trackedWalletId], references: [id], onDelete: Cascade)
  paperTrades       PaperCopyTrade[]
  paperDecisions    PaperCopyDecision[]

  @@unique([trackedWalletId, dedupeKey])
  @@index([trackedWalletId, sourceName, sourceEventId])
  @@index([trackedWalletId, sourceTxHash, logIndex])
  @@index([trackedWalletId, eventTimestamp])
  @@index([marketId, eventTimestamp])
}

model WalletSyncCursor {
  id                     String   @id @default(uuid())
  trackedWalletId        String
  sourceName             String
  sourceType             String   @default("HTTP_API")
  highWatermarkTimestamp DateTime?
  highWatermarkCursor    String?
  overlapWindowSec       Int      @default(180)
  lastSuccessAt          DateTime?
  lastFailureAt          DateTime?
  lastErrorClass         String?
  lagSec                 Int?
  status                 String   @default("ACTIVE")
  lastFetchedCount       Int      @default(0)
  lastInsertedCount      Int      @default(0)
  lastDuplicateCount     Int      @default(0)
  lastParseErrorCount    Int      @default(0)
  lastInsertErrorCount   Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  trackedWallet          WatchedWallet @relation(fields: [trackedWalletId], references: [id], onDelete: Cascade)

  @@unique([trackedWalletId, sourceName])
  @@index([sourceName, status])
}

model WalletReconciliationIssue {
  id              String   @id @default(uuid())
  trackedWalletId String
  sourceName      String   @default("POLYMARKET_DATA_API")
  issueType       String
  severity        String   @default("WARN")
  marketId        String?
  conditionId     String?
  expectedValue   Json?
  actualValue     Json?
  notes           String?
  detectedAt      DateTime @default(now())
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  trackedWallet   WatchedWallet @relation(fields: [trackedWalletId], references: [id], onDelete: Cascade)

  @@index([trackedWalletId, detectedAt])
  @@index([trackedWalletId, issueType, resolvedAt])
}

model Strategy {
  id                    String              @id @default(uuid())
  walletId              String
  name                  String
  enabled               Boolean             @default(true)
  mode                  AppMode             @default(PAPER)
  bankroll              Decimal             @default(10000)
  copiedTradesToday     Int                 @default(0)
  skippedTradesToday    Int                 @default(0)
  dailyPnl              Decimal             @default(0)
  lastCopiedTradeAt     DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  wallet                WatchedWallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  riskConfig            RiskConfig?
  decisions             CopyDecision[]
  executions            Execution[]
  positions             Position[]
  snapshots             PortfolioSnapshot[]
  backtests             BacktestRun[]
  smartConfig           SmartCopyStrategyConfig?
}

model RiskConfig {
  id                     String    @id @default(uuid())
  strategyId             String    @unique
  fixedDollar            Decimal?
  pctSourceSize          Decimal?
  pctBankroll            Decimal?
  maxExposure            Decimal
  perMarketMaxAllocation Decimal
  dailyLossCap           Decimal
  maxSlippageBps         Int
  minLiquidity           Decimal
  maxSpreadBps           Int
  inverseMode            Boolean   @default(false)
  copyBuys               Boolean   @default(true)
  copySells              Boolean   @default(true)
  cooldownSeconds        Int       @default(0)
  fillStrategy           String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  strategy               Strategy  @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model TradeEvent {
  id                  String    @id @default(uuid())
  walletId            String
  sourceEventId       String
  sourceWalletAddress String
  marketId            String
  marketQuestion      String?
  outcome             String
  side                Side
  size                Decimal
  price               Decimal
  txHash              String?
  orderId             String?
  tradedAt            DateTime
  observedAt          DateTime
  createdAt           DateTime  @default(now())
  wallet              WatchedWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  decisions           CopyDecision[]
  whaleAlerts         WhaleAlert[]
  clusterSignals      ClusterSignal[]

  @@unique([walletId, sourceEventId])
  @@index([marketId])
}

model WalletAnalyticsSnapshot {
  id                    String   @id @default(uuid())
  walletId              String
  totalTrades           Int
  wins                  Int
  losses                Int
  winRate               Decimal
  averageEntryPrice     Decimal
  averageExitPrice      Decimal
  averageHoldTime       Decimal
  profitFactor          Decimal
  realizedPnl           Decimal
  unrealizedPnl         Decimal
  maxDrawdown           Decimal
  bestTrade             Decimal
  worstTrade            Decimal
  marketDiversification Int
  tradeFrequency        Decimal
  sharpeLike            Decimal
  tradeAccuracy         Decimal
  avgTradeSize          Decimal
  marketsTraded         Int
  createdAt             DateTime @default(now())
  wallet                WatchedWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
}

model WhaleAlert {
  id              String   @id @default(uuid())
  walletId        String
  tradeEventId    String
  marketId        String
  side            Side
  price           Decimal
  size            Decimal
  notionalUsd     Decimal
  liquidity       Decimal
  reasonsJson     Json
  message         String
  createdAt       DateTime @default(now())
  wallet          WatchedWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
  tradeEvent      TradeEvent @relation(fields: [tradeEventId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
}

model ClusterSignal {
  id              String   @id @default(uuid())
  marketId        String
  side            Side
  walletIdsJson   Json
  thresholdWallets Int
  windowSeconds   Int
  firstTradeAt    DateTime
  lastTradeAt     DateTime
  eventKey        String   @unique
  triggerTradeEventId String
  createdAt       DateTime @default(now())
  triggerTradeEvent TradeEvent @relation(fields: [triggerTradeEventId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
}

model MarketIntelligenceSnapshot {
  id                 String   @id @default(uuid())
  marketId           String
  totalBuyVolume     Decimal
  totalSellVolume    Decimal
  uniqueWallets      Int
  netSentimentScore  Decimal
  buyPressure        Decimal
  sellPressure       Decimal
  createdAt          DateTime @default(now())

  @@index([marketId, createdAt])
}

model StreamEvent {
  id          String   @id @default(uuid())
  type        String
  entityId    String?
  payload     Json
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
}

model SmartCopyStrategyConfig {
  id                         String   @id @default(uuid())
  strategyId                 String   @unique
  profitableWalletsOnly      Boolean  @default(false)
  minSourceTradeUsd          Decimal?
  firstEntryOnly             Boolean  @default(false)
  ignoreExitTrades           Boolean  @default(false)
  copyClustersOnly           Boolean  @default(false)
  topRankedWalletsOnly       Boolean  @default(false)
  topRankMinWinRate          Decimal?
  topRankMinSharpeLike       Decimal?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  strategy                   Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model CopyDecision {
  id             String         @id @default(uuid())
  strategyId     String
  tradeEventId   String
  action         DecisionAction
  side           Side
  orderSize      Decimal
  limitPrice     Decimal
  reasonsJson    Json
  idempotencyKey String         @unique
  createdAt      DateTime       @default(now())
  strategy       Strategy       @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  tradeEvent     TradeEvent     @relation(fields: [tradeEventId], references: [id], onDelete: Cascade)
  execution      Execution?
}

model Execution {
  id              String          @id @default(uuid())
  strategyId      String
  decisionId      String          @unique
  mode            AppMode
  status          ExecutionStatus
  externalOrderId String?
  filledSize      Decimal
  avgFillPrice    Decimal
  feePaid         Decimal
  errorMessage    String?
  createdAt       DateTime        @default(now())
  strategy        Strategy        @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  decision        CopyDecision    @relation(fields: [decisionId], references: [id], onDelete: Cascade)
}

model Position {
  id            String    @id @default(uuid())
  strategyId    String
  marketId      String
  outcome       String
  size          Decimal
  avgPrice      Decimal
  realizedPnl   Decimal   @default(0)
  unrealizedPnl Decimal   @default(0)
  updatedAt     DateTime  @updatedAt
  strategy      Strategy  @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([strategyId, marketId, outcome])
}

model PortfolioSnapshot {
  id                String    @id @default(uuid())
  strategyId        String
  mode              AppMode
  bankroll          Decimal
  exposure          Decimal
  realizedPnl       Decimal
  unrealizedPnl     Decimal
  openPositions     Int
  copiedTradesToday Int
  skippedTradesToday Int
  createdAt         DateTime  @default(now())
  strategy          Strategy  @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model BacktestRun {
  id          String   @id @default(uuid())
  strategyId  String
  name        String
  configJson  Json
  resultJson  Json
  createdAt   DateTime @default(now())
  strategy    Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  category   String
  entityId   String
  action     String
  payload    Json
  createdAt  DateTime @default(now())

  @@index([category, entityId])
}

model PaperCopySession {
  id                    String   @id @default(uuid())
  trackedWalletId       String
  trackedWalletAddress  String
  status                String
  startingCash          Decimal
  currentCash           Decimal
  estimatedSourceExposure Decimal?
  copyRatio             Decimal?
  maxAllocationPerMarket Decimal @default(2500)
  maxTotalExposure      Decimal @default(10000)
  minNotionalThreshold  Decimal @default(2)
  minWalletTrades       Int?
  minWalletWinRate      Decimal?
  minWalletSharpeLike   Decimal?
  dailyDrawdownLimitPct Decimal?
  autoPauseOnHealthDegradation Boolean @default(false)
  consecutiveDecisionFailures Int @default(0)
  lastAutoPausedAt      DateTime?
  feeBps                Int     @default(0)
  slippageBps           Int     @default(0)
  slippageConfig        Json?
  startedAt             DateTime?
  endedAt               DateTime?
  lastProcessedEventAt  DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  trackedWallet         WatchedWallet @relation(fields: [trackedWalletId], references: [id], onDelete: Cascade)
  trades                PaperCopyTrade[]
  decisions             PaperCopyDecision[]
  positions             PaperCopyPosition[]
  snapshots             PaperPortfolioSnapshot[]
  metricPoints          PaperSessionMetricPoint[]
  systemAlerts          SystemAlert[]

  @@index([trackedWalletId, createdAt])
  @@index([status, updatedAt])
}

model SystemAlert {
  id          String   @id @default(uuid())
  dedupeKey   String   @unique
  alertType   String
  severity    String
  status      String   @default("OPEN")
  title       String
  message     String
  walletId    String?
  sessionId   String?
  payloadJson Json?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  resolvedAt  DateTime?
  count       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  wallet   WatchedWallet?   @relation(fields: [walletId], references: [id], onDelete: SetNull)
  session  PaperCopySession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([status, severity, lastSeenAt])
  @@index([alertType, lastSeenAt])
  @@index([walletId, lastSeenAt])
  @@index([sessionId, lastSeenAt])
}

model PaperCopyTrade {
  id                    String   @id @default(uuid())
  sessionId             String
  trackedWalletId       String?
  walletAddress         String?
  sourceType            String   @default("WALLET_ACTIVITY")
  sourceEventTimestamp  DateTime?
  sourceTxHash          String?
  executorType          String   @default("PAPER_SESSION_ENGINE")
  isBootstrap           Boolean  @default(false)
  sourceActivityEventId String?
  decisionId            String?
  marketId              String
  marketQuestion        String?
  outcome               String
  side                  Side
  action                String
  sourcePrice           Decimal?
  simulatedPrice        Decimal
  sourceShares          Decimal?
  simulatedShares       Decimal
  notional              Decimal
  feeApplied            Decimal
  slippageApplied       Decimal
  eventTimestamp        DateTime
  processedAt           DateTime
  reasoning             Json
  createdAt             DateTime @default(now())
  session               PaperCopySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceActivityEvent   WalletActivityEvent? @relation(fields: [sourceActivityEventId], references: [id], onDelete: SetNull)
  decision              PaperCopyDecision? @relation(fields: [decisionId], references: [id], onDelete: SetNull)

  @@unique([sessionId, sourceActivityEventId])
  @@index([sessionId, eventTimestamp])
}

model PaperCopyDecision {
  id                    String              @id @default(uuid())
  sessionId             String
  trackedWalletId       String?
  walletAddress         String?
  sourceActivityEventId String?
  sourceEventTimestamp  DateTime?
  sourceTxHash          String?
  decisionType          PaperDecisionType
  status                PaperDecisionStatus @default(PENDING)
  executorType          PaperExecutorType   @default(PAPER)
  marketId              String?
  marketQuestion        String?
  outcome               String?
  side                  Side?
  sourceShares          Decimal?
  simulatedShares       Decimal?
  sourcePrice           Decimal?
  intendedFillPrice     Decimal?
  copyRatio             Decimal?
  sizingInputsJson      Json?
  reasonCode            String
  humanReason           String
  riskChecksJson        Json?
  notes                 String?
  executionError        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  session               PaperCopySession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceActivityEvent   WalletActivityEvent? @relation(fields: [sourceActivityEventId], references: [id], onDelete: SetNull)
  trades                PaperCopyTrade[]

  @@unique([sessionId, sourceActivityEventId])
  @@index([sessionId, createdAt])
  @@index([sessionId, status, createdAt])
  @@index([sessionId, sourceEventTimestamp])
}

model PaperCopyPosition {
  id                String   @id @default(uuid())
  sessionId         String
  marketId          String
  marketQuestion    String?
  outcome           String
  netShares         Decimal
  avgEntryPrice     Decimal
  currentMarkPrice  Decimal
  realizedPnl       Decimal @default(0)
  unrealizedPnl     Decimal @default(0)
  status            String
  openedAt          DateTime
  closedAt          DateTime?
  updatedAt         DateTime @updatedAt
  session           PaperCopySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, marketId, outcome])
  @@index([sessionId, status])
}

model PaperPortfolioSnapshot {
  id                String   @id @default(uuid())
  sessionId         String
  timestamp         DateTime
  cash              Decimal
  grossExposure     Decimal
  netLiquidationValue Decimal
  realizedPnl       Decimal
  unrealizedPnl     Decimal
  totalPnl          Decimal
  returnPct         Decimal
  fees              Decimal @default(0)
  createdAt         DateTime @default(now())
  session           PaperCopySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
}

model PaperSessionMetricPoint {
  id                 String   @id @default(uuid())
  sessionId          String
  timestamp          DateTime
  totalPnl           Decimal
  realizedPnl        Decimal
  unrealizedPnl      Decimal
  netLiquidationValue Decimal
  openPositionsCount Int
  fees               Decimal @default(0)
  createdAt          DateTime @default(now())
  session            PaperCopySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
}
